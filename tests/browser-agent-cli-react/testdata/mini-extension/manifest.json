{
  "manifest_version": 3,
  "name": "Browser Agent",
  "version": "1.0.0",
  "description": "Mini fixture for browser-agent embed extract tests",
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "http://127.0.0.1:43761/*",
    "http://localhost:43761/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://127.0.0.1:43761/*",
        "http://localhost:43761/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}

{
  "manifest_version": 3,
  "name": "Browser Agent Fixture Missing Debugger",
  "version": "1.0.0",
  "description": "Missing debugger permission — must fail validate",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "alarms",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1:43761/*",
    "http://localhost:43761/*",
    "<all_urls>"
  ]
}
